{
  "expo": {
    "name": "ExpenseTracker",
    "slug": "ExpenseTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Smart Expense Logo.png",
    "scheme": "expensetracker",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/Smart Expense Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Smart Expense Logo.png",
        "backgroundImage": "./assets/images/Smart Expense Logo.png",
        "monochromeImage": "./assets/images/Smart Expense Logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.soesh_cooray.ExpenseTracker"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd3feef3-c553-4d0e-90bf-d1aaef895d8a"
      }
    }
  }
}
